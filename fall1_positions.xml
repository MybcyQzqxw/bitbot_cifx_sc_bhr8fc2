  <!-- <joint id="6" reset="1">0.0</joint> -->
  <!-- <joint id="5" reset="1">1.5</joint> -->
  <!-- <joint id="7" reset="1">0.0</joint> -->
  <!-- <joint id="0" reset="1">1.5</joint> -->
  <joint id="6">-0.8</joint>
  <joint id="5">1.2</joint>
  <joint id="7">-0.8</joint>
  <joint id="0">1.2</joint>

  <!-- 阶段2：关节 14, 15, 20, 22 -->
