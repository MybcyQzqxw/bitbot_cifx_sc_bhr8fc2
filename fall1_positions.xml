<!--
  fall1_positions.xml 示例模板
  - 根节点属性 t1/t2: 阶段时长（秒）
  - joint 元素: id 属性为关节 id，元素内容为目标位置（单位与代码中使用的一致，通常为弧度）
  示例中给出六个关节：6,5,7,0（阶段1） 和 14,15,20,22（阶段2）
-->
<fall1_positions t1="1.0" t2="5.0" deltat="0.2">
