<?xml version="1.0" encoding="utf-8"?>
<!--
  fall1_positions.xml 示例模板
  - 根节点属性 t1/t2: 阶段时长（秒）
  - joint 元素: id 属性为关节 id，元素内容为目标位置（单位与代码中使用的一致，通常为弧度）
  示例中给出六个关节：6,7（阶段1） 和 14,15,20,22（阶段2）
-->
<fall1_positions t1="2.0" t2="3.0">
  <!-- 阶段1：关节 6, 7 -->
  <joint id="6">0.0</joint>
  <joint id="7">0.0</joint>

  <!-- 阶段2：关节 14, 15, 20, 22 -->
  <joint id="14">0.6</joint>
  <joint id="15">-0.48</joint>
  <joint id="20">0.62</joint>
  <joint id="22">-0.49</joint>
</fall1_positions>
