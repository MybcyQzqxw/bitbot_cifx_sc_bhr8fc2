  <!-- <joint id="15" reset="1">-0.48</joint> -->
  <!-- <joint id="19" reset="1">-0.255</joint> -->
  <!-- <joint id="22" reset="1">-0.49</joint> -->
  <joint id="18">-0.37</joint>
  <joint id="15">-0.58</joint>
  <joint id="19">-0.355</joint>
  <joint id="22">-0.59</joint>
</fall1_positions>
